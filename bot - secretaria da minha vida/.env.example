# Token do bot criado via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# Chave da API OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=

# URL base do backend Obsidian_premium (ex.: http://localhost:4001 ou no Docker: http://backend:4000)
# Deve ser o MESMO backend que o frontend Obsidian Premium usa (fonte única: interesses e áreas).
OBSIDIAN_API_BASE_URL=

# Notas: o bot usará a API REST do Obsidian_premium para criar notas, listar categorias (interesses/áreas) e tarefas.

OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

# Opcional: caminho do arquivo de memória (default: assistant/memoria.json)
# MEMORIA_PATH=
