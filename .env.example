# ============================================================
# Variáveis de ambiente para o docker-compose
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Usuário de acesso ao painel web (padrão: admin)
AUTH_USERNAME=admin

# Senha de acesso ao painel web (OBRIGATÓRIO)
AUTH_PASSWORD=sua-senha-segura-aqui

# Segredo para assinar os tokens JWT (OBRIGATÓRIO — use uma string longa e aleatória)
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# Expiração do token JWT (padrão: 7d)
JWT_EXPIRES_IN=7d

# Chave compartilhada entre o backend e o bot do Telegram para autenticação da API
# Deve ser igual ao BOT_API_KEY no arquivo "bot - secretaria da minha vida/.env"
BOT_API_KEY=troque-por-uma-chave-aleatoria-segura
